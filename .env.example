# ==========================================
# T.A.N.U.K.I. Environment Configuration
# ==========================================

# TANUKI serving API Base URL (used by MCP bridge and adapters)
# Defaults to localhost or server IP
TANUKI_API_BASE=http://localhost:3001

# API keys for cloud-based providers (Optional: if using Gemini/OpenAI)
GEMINI_API_KEY=YOUR_GOOGLE_GEMINI_API_KEY

# REDIS config for msgpack cache (if using tanuki_mcp_adapter.py)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=V3仕様の超強力なパスワード

# Model config settings for tanuki-compiler
TANUKI_MODEL=gemma4:e4b
TANUKI_MODELS_CONFIG=config/models_config.json
TANUKI_NO_REDUCE=1

# Target directories to scan for markdown files (comma-separated relative paths)
TANUKI_TARGET_DIRS=../../Documents/InBox,../../Documents/Archive/Devlog,../../Documents/Archive/Media,../../Documents/Archive/Specifications
